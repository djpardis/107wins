<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="theme-color" content="#812583">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if ogTitle %}
  <meta property="og:title" content="{{ ogTitle }}">
  <meta property="og:description" content="{{ ogDescription or description }}">
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Syne:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
{% include "partials/header.njk" %}
<div class="site-main">
{{ content | safe }}
</div>
{% include "partials/footer.njk" %}
<script src="/js/nav-toggle.js"></script>
</body>
</html>
