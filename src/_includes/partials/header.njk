<header class="nav-float" role="banner">
  <div class="nav-float-inner">
    <div class="nav-float-menu">
      <button class="hamburger" type="button" onclick="toggleMenu()" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav" id="nav-toggle">
        <svg id="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        <svg id="close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <nav class="site-nav" id="site-nav" aria-label="Primary">
        {% for item in navigation %}
        <a href="{{ item.url }}"{% if page.url | navActive(item.url) %} class="active"{% endif %}>{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </div>
</header>
