<div class="card brand-card">
  <div class="brand-card-inner">
    <div class="brand-card-text">
      <h2 class="font-bold heading-md">Subscribe to Future Shock Media</h2>
      <form class="subscribe-form" action="{{ site.subscribeFormAction }}" method="POST">
        <input type="hidden" name="_subject" value="Future Shock Media — Publication / episode subscribe">
        <input type="hidden" name="_next" value="{{ site.url }}{{ page.url }}">
        <input type="email" id="subscribe-email" name="email" placeholder="you@example.com" required autocomplete="email" aria-label="Email">
        <button type="submit" class="btn btn-primary">Subscribe &rarr;</button>
      </form>
    </div>
  </div>
</div>
