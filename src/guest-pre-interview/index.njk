---
layout: layouts/base.njk
title: "Pre-interview information — Future Shock Media"
description: "Share your information before appearing on Future Shock Media so we can prepare for a great conversation."
permalink: /guest-pre-interview/
---

<main class="container page">
  <h1 class="section-title">Pre-interview information</h1>
  <p class="section-desc">Thank you for agreeing to be a guest on Future Shock Media! Please fill out this form with your information so we can prepare for our conversation.</p>

  <div class="card">
    <form action="https://formspree.io/f/xldnywyl" method="POST">
      <input type="hidden" name="_subject" value="Future Shock Media — Pre-Interview Info">

      <div class="form-row">
        <div class="form-group">
          <label for="name">Name *</label>
          <input type="text" id="name" name="name" placeholder="Your name" required>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="company">Company / organization</label>
          <input type="text" id="company" name="company/organization" placeholder="Your company">
        </div>
        <div class="form-group">
          <label for="jobTitle">Job title</label>
          <input type="text" id="jobTitle" name="job title" placeholder="Your role">
        </div>
      </div>

      <div class="form-group">
        <label for="introduction">How would you like to be introduced? *</label>
        <textarea id="introduction" name="how to be introduced" placeholder="A brief bio we can use to introduce you on the show..." required></textarea>
      </div>

      <div class="form-group">
        <label for="topics">Main topics you'd like to discuss *</label>
        <textarea id="topics" name="main topics to discuss" placeholder="What subjects would you like to cover in our conversation?" required></textarea>
      </div>

      <div class="form-group">
        <label for="questions">Questions you'd like us to ask</label>
        <textarea id="questions" name="questions to ask" placeholder="Any specific questions you'd like us to ask you?" class="short"></textarea>
      </div>

      <div class="form-group">
        <label for="topicsToAvoid">Topics to avoid</label>
        <textarea id="topicsToAvoid" name="topics to avoid" placeholder="Anything you'd prefer not to discuss?" class="short"></textarea>
      </div>

      <div class="form-group">
        <label for="takeaways">Key takeaways for listeners</label>
        <textarea id="takeaways" name="key takeaways for listeners" placeholder="What do you hope listeners will gain from this episode?" class="short"></textarea>
      </div>

      <div class="form-group">
        <label for="resources">Resources to share</label>
        <input type="text" id="resources" name="resources to share" placeholder="Books, articles, tools, etc. you'd recommend">
      </div>

      <div class="form-group">
        <label for="links">Relevant links</label>
        <input type="text" id="links" name="relevant links" placeholder="Website, LinkedIn, Twitter, etc.">
      </div>

      <button type="submit" class="btn btn-primary">Submit information &rarr;</button>
    </form>
  </div>
</main>
