---
layout: layouts/base.njk
title: "Blog — Future Shock Media"
description: "News and articles from Future Shock Media."
permalink: /posts/
---

<main class="container page">
  <h1 class="section-title">Blog</h1>
  <p class="section-desc">News and updates from the network.</p>

  {% if collections.posts and collections.posts.length %}
  <div class="card-list">
    {% for post in collections.posts | sortPostsPinnedFirst %}
    <article class="card{% if post.data.pinned %} card--pinned{% endif %}">
      {% if post.data.pinned %}
      <div class="card-title-row">
        <h2 class="font-semibold heading-card card-title-row__headline"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <span class="card-pin" role="img" aria-label="Pinned post">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M12 17v5"/>
            <path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/>
          </svg>
        </span>
      </div>
      {% else %}
      <h2 class="font-semibold heading-card mb-2"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      {% endif %}
      {% if post.data.description %}<p class="text-sm text-muted">{{ post.data.description }}</p>{% endif %}
      {% if post.date %}<p class="text-xs text-muted mt-2">{{ post.date | readableDate }}</p>{% endif %}
    </article>
    {% endfor %}
  </div>
  {% else %}
  <div class="card empty-state">
    <p class="text-sm text-muted">No posts yet. Add Markdown files under <code class="text-xs">src/content/posts/</code>.</p>
  </div>
  {% endif %}
</main>
